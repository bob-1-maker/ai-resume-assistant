# 服务配置
PORT=3001

# Turso 数据库配置
TURSO_DB_URL=libsql://resume-parser-bob-1-maker.aws-ap-northeast-1.turso.io
TURSO_DB_AUTH_TOKEN=你的Turso认证令牌

# 服务器配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456

# AI API 配置（选择其中一个）
# 方案1: 硅基流动
AI_API_KEY=你的AI_API_KEY
AI_BASE_URL=https://api.siliconflow.cn/v1/chat/completions

# 方案2: 豆包/火山方舟
DOUBAN_API_KEY=你的DOUBAN_API_KEY
DOUBAN_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAN_MODEL=Doubao-Seed-2.0-mini

# Redis 配置（可选）
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# 环境模式
NODE_ENV=development
